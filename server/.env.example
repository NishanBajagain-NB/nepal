# MongoDB connection string — local or Atlas cluster
MONGODB_URI=mongodb://localhost:27017/nepal_conquest

# JWT signing secret (use a long random string in production)
JWT_SECRET=change_me_to_a_random_64_char_string

# Server port
PORT=3001

# Frontend origin for CORS (comma-separated if multiple)
CORS_ORIGIN=http://localhost:5173

# Node environment
NODE_ENV=development
